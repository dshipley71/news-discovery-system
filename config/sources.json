{
  "sources": [
    {
      "id": "reddit",
      "label": "Reddit Search",
      "type": "public_api",
      "enabled": true,
      "auth_mode": "no_key",
      "endpoint": "https://www.reddit.com/search.json",
      "rss_fallback": "https://www.reddit.com/search.rss",
      "user_agent": "news-discovery-system/1.0",
      "retry_on_429": true,
      "max_attempts": 3,
      "fallback_on_empty": true
    },
    {
      "id": "google_news",
      "label": "Google News RSS",
      "type": "rss",
      "enabled": true,
      "auth_mode": "no_key",
      "endpoint": "https://news.google.com/rss/search?q={query}&hl=en-US&gl=US&ceid=US:en"
    },
    {
      "id": "web_duckduckgo",
      "label": "Web Search (DuckDuckGo HTML)",
      "type": "web_html",
      "enabled": true,
      "auth_mode": "no_key",
      "endpoint": "https://html.duckduckgo.com/html/",
      "parser_mode": "regex_fallback"
    },
    {
      "id": "gdelt",
      "label": "GDELT DOC 2.0",
      "type": "public_api",
      "enabled": true,
      "auth_mode": "no_key",
      "supports_optional_key": false,
      "endpoint": "https://api.gdeltproject.org/api/v2/doc/doc",
      "required": true
    },
    {
      "id": "hacker_news",
      "label": "Hacker News (Algolia)",
      "type": "public_discussion_api",
      "enabled": true,
      "auth_mode": "no_key",
      "endpoint": "https://hn.algolia.com/api/v1/search_by_date"
    },
    {
      "id": "twitter",
      "label": "X/Twitter Search",
      "type": "optional_api",
      "enabled": true,
      "auth_mode": "required_key",
      "endpoint": "https://api.twitter.com/2/tweets/search/recent",
      "required_env": "TWITTER_BEARER_TOKEN",
      "credential_env": "TWITTER_BEARER_TOKEN"
    }
  ]
}
